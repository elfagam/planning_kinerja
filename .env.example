APP_NAME=e-plan-ai
APP_ENV=development
HTTP_ADDR=localhost:8080
MYSQL_DSN=root@tcp(localhost:3306)/e-plan-ai?parseTime=true
DB_CONNECT_MAX_RETRIES=10
DB_CONNECT_RETRY_DELAY_SECONDS=2
GIN_MODE=debug
LOG_LEVEL=info
AUTH_ENABLED=false
AUTH_TOKEN=change-me-in-production
DEV_AUTH_USER_EMAIL=superadmin@rsudcontoh.go.id
JWT_ISSUER=e-plan-ai
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_HOURS=24
READ_TIMEOUT_SECONDS=10
WRITE_TIMEOUT_SECONDS=10
SHUTDOWN_TIMEOUT_SECONDS=10
DB_MAX_OPEN_CONNS=20
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30
DB_CONN_MAX_IDLE_TIME_MINUTES=10
